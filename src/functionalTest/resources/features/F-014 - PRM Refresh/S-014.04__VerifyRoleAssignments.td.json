          "attributes" : {
            "jurisdiction": [ "BEFTA_MASTER" ],
            "caseType" : [ "FT_CaseAccessGroups" ]
          }
        }
      ]
    }
  },
    "expectedResponse": {
      "body": {
        "roleAssignmentResponse": []
      }
    }
  }

