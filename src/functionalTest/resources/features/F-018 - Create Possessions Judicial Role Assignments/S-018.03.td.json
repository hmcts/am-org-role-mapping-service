{
  "_guid_": "S-018.03",
  "title": "must successfully create judicial role mapping for any Generic Circuit Judge Salaried appointment in Possessions",
  "_extends_": "F-018_Test_Data_Base",

  "specs": [
    "contains the actorId of the user just published who has any Generic Circuit Judge Salaried appointment in Possessions"
  ],

  "method": "POST",
  "uri": "{{ROLE_ASSIGNMENT_URL}}/am/role-assignments/query",

  "request": {
    "headers": {
      "sort": "roleName",
      "direction": "ASC",
      "Content-Type": "application/vnd.uk.gov.hmcts.role-assignment-service.post-assignment-query-request+json;charset=UTF-8;version=2.0"
    },
    "body": {
      "queryRequests":[
        {
          "actorId": [ "d85eb06c-6e1f-4485-923c-313063a32a80" ],
          "roleName": [ "hmcts-judiciary" ],
          "attributes": {
            "contractType": [ "Salaried" ]
          }
        },
        {
          "actorId": [ "${[scenarioContext][testData][request][body][queryRequests][0][actorId][0]}" ],
          "attributes": {
            "jurisdiction": [ "PCS" ]
          }
        }
      ]
    }
  },
