{
  "_guid_": "F-020_CreateCaseworkerProfileInCRD",
  "productName": "Caseworker Reference Data",
  "operationName": "Create Caseworker Profile in CRD",
  "method": "POST",
  "uri": "{{CRD_URL}}/refdata/case-worker/users/",
  "specs": [
    "to create the Financial Remedy caseworker profile",
    "to create the Financial Remedy CTSC Team Leader caseworker profile",
    "to create the Financial Remedy CTSC Admin caseworker profile",
    "to create the Financial Remedy Hearing Centre Team Leader caseworker profile",
    "to create the Financial Remedy Hearing Centre Administrator caseworker profile",
    "to create the Financial Remedy National Business Centre Team Leader caseworker profile",
    "to create the Financial Remedy National Business Centre Administrator caseworker profile"
  ],
  "users": {
    "invokingUser": {
      "_extends_": "AmBeftaUser1"
    }
  },
  "request": {
    "headers": {
      "Authorization": "[[DEFAULT_AUTO_VALUE]]",
      "ServiceAuthorization": "[[DEFAULT_AUTO_VALUE]]",
      "Content-Type": "application/json"
    },
    "body": {
      "arrayInMap": [
        {
          "first_name": "frtestuser",
          "last_name": "caseworker",
          "email_id": "${[scenarioContext][parentContext][testData][request][pathVariables][emailId]}",
          "region_id": 1,
          "region": "National",
          "user_type": "CTSC",
          "suspended": false,
          "case_allocator": "${[scenarioContext][parentContext][testData][request][pathVariables][caseAllocator]}",
          "task_supervisor": "${[scenarioContext][parentContext][testData][request][pathVariables][taskSupervisor]}",
          "idam_roles": [],
          "roles": [
            {
              "role": "${[scenarioContext][parentContext][testData][request][pathVariables][caseworkerRole]}",
              "is_primary": true
            }
          ],
          "base_location": [
            {
              "location_id": 2191654,
              "location": "Aberdeen Tribunal Hearing Centre",
              "is_primary": true
            }
          ],
          "work_area": [
            {
              "area_of_work": "Financial Remedy",
              "service_code": "ABA2"
            }
          ]
        }
      ]
    }
  },
  "expectedResponse": {
    "_extends_": "Common_201_Response",
    "headers": {
      "Content-Length": "[[ANYTHING_PRESENT]]",
      "Content-Type": "application/json"
    },
    "body": {
      "message": "Case Worker Profiles Created",
      "case_worker_ids": "[[ANYTHING_PRESENT]]"
    }
  }
}
