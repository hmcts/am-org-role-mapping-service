/*
 * Rule 5 "Generic Leadership Judge" business role mapping to JOH.
 */
rule "v1_0_possession_leadership_judge_salaried_joh"
when
    $f:  FeatureFlag(status && flagName == FeatureFlagEnum.POSSESSIONS_WA_1_0.getValue())
    $jap: JudicialAccessProfile(hasAppointmentCode(Appointment.CHIEF_INSOLVENCY_AND_COMPANIES_COURT_JUDGE)
                                        || hasAppointmentCode(Appointment.CHIEF_MASTER)
                                        || hasAppointmentCode(Appointment.DEPUTY_CHAMBER_PRESIDENT)
                                        || hasAppointmentCode(Appointment.MASTER_OF_THE_ROLLS)
                                        || hasAppointmentCode(Appointment.REGIONAL_EMPLOYMENT_JUDGE)
                                        || hasAppointmentCode(Appointment.SENIOR_MASTER)
                                        || hasValidAdditionalRole(AdditionalRole.DESIGNATED_CIVIL_JUDGE)
                                        || hasValidAdditionalRole(AdditionalRole.ACTING_DESIGNATED_CIVIL_JUDGE),
                                isSalaried(),
                                hasValidEndDate(),
                                hasValidAuthorisation(Jurisdiction.POSSESSIONS))
then

    insert(
        JudicialOfficeHolder.builder()
            .userId($jap.getUserId())
            .office(Office.Possessions.POSSESSION_LEADERSHIP_JUDGE_SALARIED)
            .jurisdiction(Jurisdiction.POSSESSIONS.getName())
            .ticketCodes($jap.getTicketCodes())
            .beginTime($jap.getBeginTime())
            .endTime($jap.getEndTime())
            .regionId(regionId)
            .baseLocationId($jap.getBaseLocationId())
            .primaryLocation($jap.getPrimaryLocationId())
            .contractType($jap.getAppointmentType())
            .build()
    );

    logMsg("Rule : v1_0_possession_leadership_judge_salaried_joh");
end;

