/*
 * Rule 3 "Generic Circuit Judge Salaried" business role mapping to JOH.
 */
rule "v1_0_possession_circuit_judge_salaried_joh"
when
    $f:  FeatureFlag(status && flagName == FeatureFlagEnum.POSSESSIONS_WA_1_0.getValue())
    $jap: JudicialAccessProfile(hasAppointmentCode(Appointment.CIRCUIT_JUDGE)
                                        || hasAppointmentCode(Appointment.CIRCUIT_JUDGE_CENTRAL_CRIMINAL_COURT)
                                        || hasAppointmentCode(Appointment.COURT_OF_APPEAL_JUDGE)
                                        || hasAppointmentCode(Appointment.HIGH_COURT_JUDGE)
                                        || hasAppointmentCode(Appointment.SENIOR_CIRCUIT_JUDGE)
                                        || hasAppointmentCode(Appointment.SPECIALIST_CIRCUIT_JUDGE)
                                        || hasValidAdditionalRole(AdditionalRole.PRESIDING_JUDGE)
                                isSalaried(),
                                hasValidEndDate(),
                                hasValidAuthorisation(Jurisdiction.POSSESSIONS))
then

    insert(
        JudicialOfficeHolder.builder()
            .userId($jap.getUserId())
            .office(Office.Possessions.POSSESSION_CIRCUIT_JUDGE_SALARIED)
            .jurisdiction(Jurisdiction.POSSESSIONS.getName())
            .ticketCodes($jap.getTicketCodes())
            .beginTime($jap.getBeginTime())
            .endTime($jap.getEndTime())
            .regionId(regionId)
            .baseLocationId($jap.getBaseLocationId())
            .primaryLocation($jap.getPrimaryLocationId())
            .contractType($jap.getAppointmentType())
            .build()
    );

    logMsg("Rule : v1_0_possession_circuit_judge_salaried_joh");
end;

